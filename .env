# ─────────────────────────────────────────────────────────────────────────────
# LOCAL SECRETS — NEVER COMMIT.
#
# ⚠️  This file was tracked in git (ca78a0e, 6622bfc, 1556673, 40d1411).
#     `.gitignore` lists it, but the rule never applied because the file was
#     already tracked. It has now been untracked.
#     The Google Maps key below is present in that public history and MUST be
#     rotated in Google Cloud Console. It is left intact here so the current dev
#     build keeps working until you rotate it.
# ─────────────────────────────────────────────────────────────────────────────

# ── General / app ────────────────────────────────────────────────────────────
APP_NAME=ISI STEEL SALES
APP_ENV=development

# Master switches. ENABLE_MOCK swaps the SAP remote datasource for the in-memory
# mock at DI time — repository, bloc and UI are identical either way.
ENABLE_MOCK=true
ENABLE_SYNC=true

# Logs endpoint + status code only. Never bodies, never headers (SECURITY.md §10).
LOG_NETWORK=true

# ── SAP backend (S/4HANA Private Cloud via the SapAPI ASP.NET façade) ────────
# Auth is JWT: POST /api/Auth/Login -> {token, expiresAt}. There is NO refresh
# endpoint; the token expires after ~60 min and the client re-authenticates.
#
# Credentials are per-user (entered at login, JWT held in flutter_secure_storage)
# and are deliberately NOT stored here: a service account compiled into the
# binary is recoverable from the APK. Envied obfuscates, it does not encrypt.
SAP_BASE_URL_PRIMARY=https://192.168.100.112:4451
SAP_BASE_URL_FALLBACK=https://136.228.141.130:4451

# SAP connection id — selects the target SAP system (DEV / QAS / PRD).
# Required path segment on every Customer and CustHelper call.
SAP_CON_ID=Live110

SAP_TIMEOUT_MS=30000

# SAP-side paging. The technical doc advises keeping this at 50 or below.
SAP_PAGE_SIZE=50

# Base64 SHA-256 of the SAP server certificate (DER form).
# The host serves HTTPS on a raw IP with a self-signed certificate, so ordinary
# CA validation cannot succeed. Leave EMPTY to fail closed (SAP calls refused).
# Refresh this value whenever the server certificate is renewed.
# Obtain with:
#   openssl s_client -connect 192.168.100.112:4451 </dev/null 2>/dev/null \
#     | openssl x509 -outform der \
#     | openssl dgst -sha256 -binary | openssl enc -base64
SAP_CERT_SHA256=

# ── ISI Steel Sales backend (auth, profile, notifications, config, analytics) ─
# Deliberately separate from SAP: different host, client, and interceptors.
# Nothing SAP-shaped may be added here.
ISI_API_URL=https://136.228.141.130:4451
ISI_TIMEOUT_MS=30000
ISI_API_VERSION=v1

# ── Maps ─────────────────────────────────────────────────────────────────────
# ⚠️ ROTATE — leaked in committed git history (see header).
GOOGLE_MAPS_ANDROID_KEY=AIzaSyCNtNin7cX7lQnWgGqBh81Dw-Hit0_L_vc
GOOGLE_MAPS_IOS_KEY=AIzaSyCNtNin7cX7lQnWgGqBh81Dw-Hit0_L_vc
MAP_PROVIDER=google

# ── Database ─────────────────────────────────────────────────────────────────
# DO NOT CHANGE. Combined with the hardware-sealed device key to derive the
# SQLCipher passphrase (DATABASE_GUIDE.md §2.1). Changing this value renders
# every existing encrypted database on every device permanently unreadable.
DB_SALT=e7b4c92a10dcf85b4138e93d9a74fe11
