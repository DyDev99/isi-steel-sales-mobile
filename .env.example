# Committed template — copy to `.env` and fill real values. NO real secrets here.
# `.env` is git-ignored; Envied compiles these into obfuscated Dart at build time.

APP_NAME=ISI STEEL SALES
APP_ENV=development
API_BASE_URL=https://dev-api.example.com
API_TIMEOUT=30000
ENABLE_LOGGING=true
ENABLE_DEBUG=true

GOOGLE_MAPS_ANDROID_KEY=your_dev_android_key
GOOGLE_MAPS_IOS_KEY=your_dev_ios_key
MAP_PROVIDER=google
AUTH_TOKEN_KEY=dev_access_token
LOCAL_DB_NAME=myapp_dev.db
ANALYTICS_ENABLED=false

# Blueprint: SAP gateway + database encryption salt (combined with the
# hardware-sealed device key to derive the SQLCipher passphrase).
SAP_API_URL=https://<env>.sap-gateway.company.internal/api/v2
DB_SALT=<32-hex-char-random-salt>
