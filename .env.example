# Committed template — NO real secrets here.
#
# Obfuscation is not encryption. Anything placed here is recoverable from a
# shipped binary — put only values you accept as semi-public. Per-user
# credentials and bearer tokens belong in flutter_secure_storage, never in this
# file (docs/SECURITY.md §3).
#
# ── How environment switching works ─────────────────────────────────────────
# Envied compiles a single fixed path (`.env`) into obfuscated Dart at build
# time, so switching environments means swapping which file *is* `.env`:
#
#   cp .env.development .env    # or .env.staging / .env.production
#   dart run build_runner build --delete-conflicting-outputs
#   dart run tool/generate_ios_env.dart      # iOS only: native Maps key
#   flutter build appbundle --obfuscate --split-debug-info=build/symbols
#
# `.env` and `.env.*` are git-ignored; CI writes them from GitHub Secrets.
# Android reads GOOGLE_MAPS_ANDROID_KEY straight from `.env` via a Gradle
# manifest placeholder; iOS goes through tool/generate_ios_env.dart.

# ── General / app ────────────────────────────────────────────────────────────
APP_NAME=ISI STEEL SALES
APP_ENV=development

# ENABLE_MOCK swaps the SAP remote datasource for the in-memory mock at DI time
# — repository, bloc and UI are identical either way.
ENABLE_MOCK=true
ENABLE_SYNC=true

# Logs endpoint + status code only. Never bodies, never headers (SECURITY.md §10).
# Must be false in staging/production builds (SECURITY.md §11).
LOG_NETWORK=true

# ── SAP backend (S/4HANA Private Cloud via the SapAPI ASP.NET façade) ────────
# Auth is JWT (POST /api/Auth/Login). No refresh endpoint exists — the ~60 min
# token is renewed by re-authenticating. Credentials are per-user and are NOT
# configured here.
SAP_BASE_URL_PRIMARY=https://<lan-ip>:4451
SAP_BASE_URL_FALLBACK=https://<public-ip>:4451
SAP_CON_ID=<DEV|QAS|PRD>
SAP_TIMEOUT_MS=30000
SAP_PAGE_SIZE=50

# Base64 SHA-256 of the SAP server certificate (DER). Empty = fail closed.
# openssl s_client -connect <host>:4451 </dev/null 2>/dev/null \
#   | openssl x509 -outform der \
#   | openssl dgst -sha256 -binary | openssl enc -base64
SAP_CERT_SHA256=

# ── ISI Steel Sales backend (auth, profile, notifications, config, analytics) ─
ISI_API_URL=https://<isi-host>
ISI_TIMEOUT_MS=30000
ISI_API_VERSION=v1

# ── Maps ─────────────────────────────────────────────────────────────────────
# Restrict these by package name + SHA-1 (Android) and bundle ID (iOS) in the
# Google Cloud console — an unrestricted Maps key is billable by anyone who has it.
GOOGLE_MAPS_ANDROID_KEY=your_dev_android_key
GOOGLE_MAPS_IOS_KEY=your_dev_ios_key

MAP_PROVIDER=google

# ── Database ─────────────────────────────────────────────────────────────────
# Combined with the hardware-sealed device key to derive the SQLCipher
# passphrase (docs/DATABASE_GUIDE.md §2.1). Use a DIFFERENT value per
# environment, and never commit a real one: changing it makes every existing
# encrypted database on every device permanently unreadable.
DB_SALT=<32-hex-char-random-salt>
