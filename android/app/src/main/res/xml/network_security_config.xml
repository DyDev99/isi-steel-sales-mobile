<?xml version="1.0" encoding="utf-8"?>
<!--
  Scopes the SAP cleartext exemption to a single host.

  This is the file the AndroidManifest TODO(release-gate) note asks for: with
  `networkSecurityConfig` set, this config governs cleartext policy and the
  manifest's `usesCleartextTraffic="true"` becomes a no-op fallback for API
  levels that ignore this file. The base-config below therefore restores the
  HTTPS-only default that docs/SECURITY.md §6 requires, and permits plaintext
  for the SAP dev IP alone.

  The `debug-overrides` block trusts user-installed CAs so a locally installed
  dev certificate works — but only in debug builds, and only for Android's own
  HTTP stack. Cronet keeps a private trust store and does not read this file,
  so it does not help SapTransport.native.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.100.112</domain>
    </domain-config>

    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>